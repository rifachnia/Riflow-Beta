RIFLOW_MODE=paper
RIFLOW_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
RIFLOW_WALLET_PUBLIC_KEY=
RIFLOW_METEORA_API_URL=

# Optional: switch scanner sources with data/config.json:
# scanner.source = "meteora-dlmm" for real Meteora pool data
# scanner.source = "local-sim" for offline fake data
# Runtime/risk/strategy values are centralized in data/config.json:
# strategy, dlmm, management, risk, scanner, paperTrading, memory, analytics

# Xiaomi MiMo via local gitlawb proxy. This avoids copying any old API key.
LLM_BASE_URL=http://127.0.0.1:19911/v1
LLM_API_KEY=local-proxy
LLM_MODEL=mimo-v2.5-pro
